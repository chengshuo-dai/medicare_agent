# ==========================================
# MediCareAI-Agent — Environment Configuration
# ==========================================
# Copy this file to .env and fill in real values.
# .env is gitignored — NEVER commit secrets.
#
# For Railway deployment:
#   - DATABASE_URL and REDIS_URL are auto-set by plugins
#   - Set all other required vars in Railway dashboard
#   - Required: SECRET_KEY, API_KEY_MASTER_KEY, DEEPSEEK_API_KEY
# ==========================================

# ── Application ───────────────────────────
APP_NAME=MediCareAI-Agent
APP_VERSION=0.1.0
DEBUG=false
ENVIRONMENT=development
SECRET_KEY=change-this-to-a-64-char-random-string

# ── Database (PostgreSQL + pgvector) ──────
# Railway: auto-set by PostgreSQL plugin → use DATABASE_URL directly
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/medicareai

# ── Redis ─────────────────────────────────
# Railway: auto-set by Redis plugin → use REDIS_URL directly
REDIS_URL=redis://localhost:6379/0

# ── Celery ────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
# Set to true for local dev without Celery worker
CELERY_TASK_ALWAYS_EAGER=false

# ── Encryption Master Key (REQUIRED) ──────
# Used to encrypt LLM API keys stored in DB.
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
API_KEY_MASTER_KEY=change-me

# ── LLM Providers ─────────────────────────
# DeepSeek (primary — at least this one is required)
DEEPSEEK_API_KEY=sk-your-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# Optional additional providers
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
# MOONSHOT_API_KEY=
# MOONSHOT_BASE_URL=https://api.moonshot.cn/v1
# DASHSCOPE_API_KEY=
# DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ── Default Admin ──────────────────────────
DEFAULT_ADMIN_EMAIL=admin@medicareai.dev
DEFAULT_ADMIN_PASSWORD=change-me-on-first-login

# ── CORS (comma-separated origins) ────────
# Local: http://localhost:3000,http://localhost:5173
# Production: https://your-app.vercel.app
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Guest Mode ────────────────────────────
GUEST_SESSION_TTL_HOURS=24
GUEST_MAX_MESSAGES=10

# ── Monitoring ────────────────────────────
SENTRY_DSN=
